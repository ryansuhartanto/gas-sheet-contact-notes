{
  "name": "gas-sheet-contact",
  "private": true,
  "description": "Spreadsheet contact database in Google Apps Script",
  "author": {
    "name": "Ryan Suhartanto",
    "email": "suhartanto@kekkon.nexus"
  },
  "type": "commonjs",
  "scripts": {
    "prepare": "husky",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "build": "tsc --build && oxfmt ./dist --write && cp appsscript.json ./dist/src"
  },
  "devDependencies": {
    "@google/clasp": "^3.2.0",
    "@types/bun": "latest",
    "@types/google-apps-script": "^2.0.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "typescript": "^6.0.1-rc",
    "ultracite": "7.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun run fix"
    ]
  }
}
