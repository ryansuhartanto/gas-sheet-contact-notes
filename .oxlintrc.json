{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["./node_modules/ultracite/config/oxlint/core/.oxlintrc.json"],
  "rules": {
    "eslint/func-style": [
      "warn",
      "declaration",
      { "allowArrowFunctions": true }
    ],
    "eslint/max-statements": ["off"],
    "eslint/no-unused-vars": ["off"]
  }
}
